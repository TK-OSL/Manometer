        langToggle.addEventListener('change', updateUI);

        // ==========================================
        // 3. ฟังก์ชันคำนวณและอัปเดตสำหรับ Interactive Model
        // ==========================================
        function updateCalculation(p_gauge) {
            const h_m = p_gauge / (1000 * 9.8); // เมตร
            const h_cm = h_m * 100;             // เซนติเมตร
            const p_atm = 101325;
            const p_abs = p_atm + p_gauge;
            
            // อัปเดตตัวเลขใน DOM (ใช้ textContent เพื่อไม่ลบ HTML Tags ภายใน)
            document.getElementById('pressureValue').textContent = p_gauge.toLocaleString();
            document.getElementById('dynP1').textContent = p_gauge.toLocaleString();
            document.getElementById('dynP2').textContent = p_gauge.toLocaleString();
            document.getElementById('dynH_m').textContent = h_m.toFixed(4);
            document.getElementById('dynH_cm').textContent = h_cm.toFixed(2);
            document.getElementById('dynPabs').textContent = p_abs.toLocaleString();
            
            // สั่งวาด Canvas รูปหลอดตัวยูใหม่ตามค่า h
            drawManometer(p_gauge, h_cm);
        }

        // ==========================================
        // 4. ฟังก์ชันคำนวณสำหรับ Example Problem 
        // ==========================================
        function updateExampleCalculation() {
            // อ่านค่าจากช่อง Input ทั้งหมด
            let h_val = parseFloat(exampleInput.value);
            let rho_val = parseFloat(exampleLiquid.value);
            let patm_val = parseFloat(examplePatm.value);
            
            // ตรวจสอบค่าถ้าผู้ใช้ลบจนว่างหรือติดลบ ให้ใช้ 0
            if (isNaN(h_val) || h_val < 0) h_val = 0;
            if (isNaN(patm_val) || patm_val < 0) patm_val = 0;
            
            const h_m = h_val / 100;
            const p_gauge = rho_val * 9.8 * h_m;
            const p_abs = patm_val + p_gauge;
            
            // จัด Format มีจุลภาค
            const rho_str = rho_val.toLocaleString();
            const patm_str = patm_val.toLocaleString();
            const p_gauge_str = p_gauge.toLocaleString(undefined, {maximumFractionDigits: 1});
            const p_abs_str = p_abs.toLocaleString(undefined, {maximumFractionDigits: 1});

            // เปลี่ยนสีของเหลวใน SVG ตัวอย่างโจทย์
            let fluidColor = "#3b82f6"; // สีน้ำเงิน (น้ำ)
            if (rho_val === 13600) fluidColor = "#94a3b8"; // สีเทาเงิน (ปรอท)
            else if (rho_val === 850) fluidColor = "#eab308"; // สีเหลืองทอง (น้ำมัน)
            document.getElementById('svgFluidPath').setAttribute("stroke", fluidColor);

            // อัปเดตค่าในบรรทัด (Given: ...)
            document.getElementById('givenRho').textContent = rho_str;
            document.getElementById('givenPatm').textContent = patm_str;

            // แสดงผลในกล่อง Solution
            document.getElementById('exSolH_cm').textContent = h_val;
            document.getElementById('exSolH_m').textContent = h_m.toFixed(2);
            document.getElementById('exSolH_m2').textContent = h_m.toFixed(2);
            document.getElementById('exSolRho').textContent = rho_str;
            document.getElementById('exSolPatm').textContent = patm_str;
            document.getElementById('exSolGauge').textContent = p_gauge_str;
            document.getElementById('exSolGauge2').textContent = p_gauge_str;
            document.getElementById('exSolAbs').textContent = p_abs_str;
            
            // อัปเดตตัวหนังสือชี้ระยะ h ในกราฟิก SVG
            document.getElementById('svgExampleHText').textContent = `h = ${h_val} cm`;
        }

        // ฟังอีเวนต์เมื่อมีการแก้ไขค่าในโจทย์
        exampleInput.addEventListener('input', updateExampleCalculation);
        exampleLiquid.addEventListener('change', updateExampleCalculation);
        examplePatm.addEventListener('input', updateExampleCalculation);
        
        pressureSlider.addEventListener('input', function() {
            updateCalculation(parseFloat(this.value));
        });

        // ==========================================
        // 5. ระบบวาดแบบจำลอง (Advanced Canvas Logic)
        // ==========================================
        const canvas = document.getElementById('manometerCanvas');
        const ctx = canvas.getContext('2d');

        // การตั้งค่าขนาดและพิกัดท่อ (ใช้ตัวเลขเดียวกับ SVG เพื่อให้สัดส่วนตรงกัน)
        const cx = 260;           // กึ่งกลางหลอด
        const radius = 70;        // รัศมีส่วนโค้งของตัวยู
        const tubeThickness = 26; // ความหนาเส้นกรอบนอก
        const innerThickness = 20;// ความหนาช่องของไหล
        
        const topY = 80;          // ความสูงปลายเปิด
        const bottomY = 290;      // ฐานหลอดตัวยู
        const baseLevel = 190;    // ระดับน้ำตอนสมดุล
        
        const tankX = cx - radius - 50; 
        const tankY = 110; 

        function drawManometer(pressure, h_cm) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // ขยายสเกลความสูงเพื่อให้เห็นชัดเวลาวาด (Scale factor)
            const h_pixels = h_cm * 2.5; 
            const leftLevel = baseLevel + (h_pixels / 2);
            const rightLevel = baseLevel - (h_pixels / 2);

            const fontFamily = currentLang === 'en' ? 'Inter' : 'Sarabun';
            const gasText = i18n[currentLang].canvasGas;
            const patmText = i18n[currentLang].canvasPatm;

            // เทคนิคการวาดให้เป็นชิ้นเดียวกันโดยไม่ให้มีเส้นขีดคั่นกลาง:
            // เราจะวาดเป็นชั้นๆ (Layer) โดยวาดรูปทรงรวม (ถัง+ท่อ) ก่อน แล้วค่อยถมสีด้านใน

            // กำหนดรูปแบบปลายเส้นและรอยต่อให้โค้งมน เพื่อความสมูท
            ctx.lineJoin = "round";
            // ปลายหลอดตัดตรง (butt) เพื่อสื่อว่าเป็นท่อปลายเปิด
            ctx.lineCap = "butt";

            // --- Layer 1: พื้นหลังส่วนกรอบนอกสุด (สีเทาเข้ม) ---
            ctx.fillStyle = "#475569";
            ctx.beginPath();
            ctx.arc(tankX, tankY, 40, 0, Math.PI * 2);
            ctx.fill();

            ctx.strokeStyle = "#475569"; 
            ctx.lineWidth = tubeThickness;
            ctx.beginPath();
            ctx.moveTo(tankX, tankY);               // เริ่มจากกึ่งกลางถังแก๊ส
            ctx.lineTo(cx - radius, tankY);         // ลากไปท่อซ้าย
            ctx.lineTo(cx - radius, bottomY);       // ลงมาฐาน
            ctx.arc(cx, bottomY, radius, Math.PI, 0, true); // โค้งตัวยู
            ctx.lineTo(cx + radius, topY);          // ขึ้นท่อขวา
            ctx.stroke();

            // --- Layer 2: พื้นหลังส่วนกระจกท่อ (สีขาวเทา) ลบเส้นที่ตัดกันออก ---
            ctx.fillStyle = "#f8fafc";
            ctx.beginPath();
            ctx.arc(tankX, tankY, 38, 0, Math.PI * 2);
            ctx.fill();

            ctx.strokeStyle = "#f8fafc";
            ctx.lineWidth = innerThickness;
            ctx.beginPath();
            ctx.moveTo(tankX, tankY);
            ctx.lineTo(cx - radius, tankY);
            ctx.lineTo(cx - radius, bottomY);
            ctx.arc(cx, bottomY, radius, Math.PI, 0, true);
            ctx.lineTo(cx + radius, topY);
            ctx.stroke();

            // --- Layer 3: ถมสีส่วนที่เป็นแก๊ส (สีเทาอ่อน) ---
            ctx.fillStyle = "#cbd5e1";
            ctx.beginPath();
            ctx.arc(tankX, tankY, 38, 0, Math.PI * 2);
            ctx.fill();

            ctx.strokeStyle = "#cbd5e1"; 
            ctx.lineWidth = innerThickness;
            ctx.beginPath();
            ctx.moveTo(tankX, tankY);
            ctx.lineTo(cx - radius, tankY);
            ctx.lineTo(cx - radius, leftLevel); // วาดแก๊สลงมาถึงแค่ระดับน้ำซ้าย
            ctx.stroke();

            // --- Layer 4: ถมสีส่วนที่เป็นน้ำ (สีฟ้า) ---
            ctx.strokeStyle = "#3b82f6";
            ctx.lineWidth = innerThickness;
            ctx.beginPath();
            ctx.moveTo(cx - radius, leftLevel); // เริ่มจากระดับน้ำซ้าย
            ctx.lineTo(cx - radius, bottomY);
            ctx.arc(cx, bottomY, radius, Math.PI, 0, true);
            ctx.lineTo(cx + radius, rightLevel); // ไปจบรอยต่อระดับน้ำขวา
            ctx.stroke();

            // --- Layer 5: ข้อความและลูกศรประกอบ ---
            
            // ข้อความกำกับ: แก๊ส
            ctx.fillStyle = "#334155"; 
            ctx.font = `bold 18px ${fontFamily}`;
            ctx.textAlign = "center";
            ctx.fillText(gasText, tankX, tankY + 5);

            // ข้อความกำกับ: P atm
            ctx.fillStyle = "#64748b"; 
            ctx.font = `14px ${fontFamily}`;
            ctx.fillText(patmText, cx + radius, topY - 35);
            
            // ลูกศรแสดงความดันบรรยากาศชี้ลงเข้าปลายเปิด
            ctx.strokeStyle = "#94a3b8"; 
            ctx.lineWidth = 2;
            for(let i = -1; i <= 1; i++) {
                let ax = cx + radius + (i*8);
                ctx.beginPath();
                ctx.moveTo(ax, topY - 25);
                ctx.lineTo(ax, topY - 8);
                ctx.stroke();
                // วาดหัวลูกศร
                ctx.beginPath();
                ctx.moveTo(ax, topY - 8);
                ctx.lineTo(ax - 4, topY - 13);
                ctx.lineTo(ax + 4, topY - 13);
                ctx.fillStyle = "#94a3b8";
                ctx.fill();
            }

            // --- Layer 6: เส้นบอกระยะความต่างระดับ h ---
            if (h_pixels > 1) {
                ctx.strokeStyle = "#ef4444"; // สีแดงสำหรับเน้น
                ctx.lineWidth = 1.5;
                ctx.setLineDash([5, 4]); // กำหนดเป็นเส้นประ
                
                // ขีดเส้นระดับน้ำซ้าย
                ctx.beginPath();
                ctx.moveTo(cx - radius + 10, leftLevel);
                ctx.lineTo(cx + radius + 60, leftLevel);
                ctx.stroke();
                
                // ขีดเส้นระดับน้ำขวา
                ctx.beginPath();
                ctx.moveTo(cx + radius + 10, rightLevel);
                ctx.lineTo(cx + radius + 60, rightLevel);
                ctx.stroke();
                
                ctx.setLineDash([]); // กลับมาใช้เส้นทึบปกติ

                // วาดแกนลูกศรความสูงแนวตั้ง
                const arrowX = cx + radius + 40;
                ctx.beginPath();
                ctx.moveTo(arrowX, rightLevel);
                ctx.lineTo(arrowX, leftLevel);
                ctx.stroke();

                // วาดหัวลูกศรด้านบน
                ctx.beginPath();
                ctx.moveTo(arrowX, rightLevel);
                ctx.lineTo(arrowX - 5, rightLevel + 8);
                ctx.lineTo(arrowX + 5, rightLevel + 8);
                ctx.fillStyle = "#ef4444";
                ctx.fill();

                // วาดหัวลูกศรด้านล่าง
                ctx.beginPath();
                ctx.moveTo(arrowX, leftLevel);
                ctx.lineTo(arrowX - 5, leftLevel - 8);
                ctx.lineTo(arrowX + 5, leftLevel - 8);
                ctx.fill();
                
                // พื้นหลังข้อความ h เล็กน้อยให้อ่านง่าย
                ctx.fillStyle = "rgba(255, 255, 255, 0.8)";
                ctx.fillRect(arrowX + 12, baseLevel - 10, 25, 20);
                
                // พิมพ์ข้อความ h
                ctx.fillStyle = "#ef4444";
                ctx.font = `bold 18px ${fontFamily}`;
                ctx.textAlign = "left";
                ctx.fillText("h", arrowX + 15, baseLevel + 5);
            }
        }

        // ==========================================
        // 6. การกำหนดค่าเมื่อเริ่มต้นหน้าจอ (Initialization)
        // ==========================================
        window.onload = function() {
            langToggle.checked = false; // เริ่มที่ภาษาอังกฤษ
            updateUI();                 // โหลดคำแปลภาษาลง UI
            updateExampleCalculation(); // เริ่มคำนวณโจทย์ด้วยค่าตั้งต้น
        };

    </script>
</body>
